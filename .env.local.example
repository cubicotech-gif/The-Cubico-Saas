# Supabase
NEXT_PUBLIC_SUPABASE_URL=your-supabase-url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# Admin Auth (simple password-based for now)
NEXT_PUBLIC_ADMIN_PASSWORD=cubico-admin-2026

# ── PayPal ─────────────────────────────────────────────────────────────
# Create a REST API app at https://developer.paypal.com → Apps & Credentials.
# Use "Sandbox" credentials for testing, "Live" for production.
PAYPAL_CLIENT_ID=your-paypal-client-id
PAYPAL_CLIENT_SECRET=your-paypal-client-secret
PAYPAL_ENVIRONMENT=sandbox
# Exposed to the browser so the PayPal JS SDK can render the buttons.
NEXT_PUBLIC_PAYPAL_CLIENT_ID=your-paypal-client-id
# PayPal processes in USD. Orders priced in PKR are converted at this rate.
PKR_TO_USD_RATE=280
